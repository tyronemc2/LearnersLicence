# Example server block for ll.scanme.site (nginx).
# Install under /etc/nginx/sites-available/ (or include from your layout),
# then: sudo nginx -t && sudo systemctl reload nginx
#
# After each deploy: npm ci && npm run build

# Preferred: document root is the build output
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ll.scanme.site;

    root /data/www/ll.scanme.site/dist;
    index index.html;

    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        try_files $uri =404;
    }

    location ~* \.(js|css)$ {
        add_header Cache-Control "no-cache, must-revalidate";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}

# Alternative: git checkout root stays the nginx root (try_files serves dist/)
